# ─── Barcode Server — Environment template (safe to commit) ────────────
NODE_ENV=development
PORT=5001

# MongoDB connection string
DATABASE_URL=your_mongodb_connection_string

# Auth
BCRYPT_SALT_ROUNDS=12
JWT_ACCESS_SECRET=your_access_secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Client URL (frontend origin)
CLIENT_URL=http://localhost:5173

# Public API origin — used for the SSLCommerz IPN callback. Set this to the real
# API domain in production (e.g. https://barcoderestaurantgroup.com). Left empty
# it falls back to the client host on port 5001 (dev only).
SERVER_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SSLCommerz — from the merchant panel. Leave STORE_ID/PASS empty for demo mode.
# Use sandbox credentials with IS_LIVE=false to test, then live creds + IS_LIVE=true.
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_LIVE=false
